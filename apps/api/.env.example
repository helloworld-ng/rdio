API_PORT=3001
DATABASE_URL=postgres://rdio:rdio@localhost:5432/rdio
# Allowed browser origins (comma-separated). Include every site that calls the API.
WEB_ORIGIN=http://localhost:5173
# Production example:
# WEB_ORIGIN=https://rdio-web.fly.dev,https://radio.16by16.co
# Replace this development-only value with a strong random secret in production.
BETTER_AUTH_SECRET=dev-only-change-me-dev-only-change-me
BETTER_AUTH_URL=http://localhost:3001
# Local Docker Compose publishes Icecast on this port.
ICECAST_PORT=8000
HARBOR_PORT=8005
HARBOR_TLS_PORT=8443
# Public Icecast origin used to build stream URLs in API responses.
PUBLIC_STREAM_BASE_URL=http://localhost:8000
# Public hostname for BUTT/Harbor connections (defaults to PUBLIC_STREAM_BASE_URL host).
# BROADCAST_HOST=rdio-api.fly.dev
ICECAST_SOURCE_PASSWORD=sourcepass
