POSTGRES_DB=rdio
POSTGRES_USER=rdio
POSTGRES_PASSWORD=rdio
DATABASE_URL=postgres://rdio:rdio@localhost:5432/rdio
API_PORT=3001
WEB_PORT=5173
# Restrict API CORS to this origin. Set to your web app's public URL in production.
WEB_ORIGIN=http://localhost:5173
# Replace this development-only value with a strong random secret in production.
BETTER_AUTH_SECRET=dev-only-change-me-dev-only-change-me
BETTER_AUTH_URL=http://localhost:3001
# URL of the running API, used by the web app. Set to your API's public URL for production builds.
VITE_API_BASE_URL=http://localhost:3001
ICECAST_HOST=localhost
ICECAST_PORT=8000
# Public Icecast origin used to build streamUrl in API responses. Set to your Icecast host in production.
PUBLIC_STREAM_BASE_URL=http://localhost:8000
ICECAST_SOURCE_PASSWORD=sourcepass
ICECAST_ADMIN_PASSWORD=adminpass
ICECAST_MOUNT=/rdio.mp3
